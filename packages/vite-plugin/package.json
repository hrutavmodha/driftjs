{
  "name": "@driftjs/vite-plugin",
  "version": "0.0.0",
  "description": "Vite plugin for compiling .drift single-file component templates into reactive VM bytecode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@driftjs/compiler": "workspace:*",
    "@driftjs/runtime": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=7.0.0"
  },
  "type": "module"
}
