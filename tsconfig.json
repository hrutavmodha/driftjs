{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "paths": {
      "driftjs": ["./packages/runtime/index.ts"],
      "driftjs/*": ["./packages/runtime/*"],
      "@driftjs/compiler": ["./packages/compiler/index.ts"],
      "@driftjs/compiler/src": ["./packages/compiler/src/index.ts"],
      "@driftjs/compiler/lexer": ["./packages/compiler/src/lexer/index.ts"],
      "@driftjs/compiler/parser": ["./packages/compiler/src/parser/index.ts"],
      "@driftjs/compiler/analyzer": ["./packages/compiler/src/analyzer/index.ts"],
      "@driftjs/compiler/generator": ["./packages/compiler/src/generator/index.ts"],
      "@driftjs/compiler/types": ["./packages/compiler/types/index.ts"],
      "@driftjs/compiler/*": ["./packages/compiler/*"],
      "@driftjs/runtime": ["./packages/runtime/index.ts"],
      "@driftjs/runtime/src": ["./packages/runtime/src/index.ts"],
      "@driftjs/runtime/types": ["./packages/runtime/types/index.ts"],
      "@driftjs/runtime/*": ["./packages/runtime/*"],
      "@driftjs/vite-plugin": ["./packages/vite-plugin/index.ts"],
      "@driftjs/vite-plugin/src": ["./packages/vite-plugin/src/index.ts"],
      "@driftjs/vite-plugin/types": ["./packages/vite-plugin/types/index.ts"],
      "@driftjs/vite-plugin/*": ["./packages/vite-plugin/*"],
      "vite-plugin-drift": ["./packages/vite-plugin/index.ts"]
    },

    // Environment Settings
    "module": "nodenext",
    "target": "esnext",
    "types": [],

    // Other Outputs
    "noEmit": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
